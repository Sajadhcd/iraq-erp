  type           AccountType
  parentId       String?       @map("parent_id") @db.Uuid
  isActive       Boolean       @default(true) @map("is_active")
  isCashOrBank   Boolean       @default(false) @map("is_cash_or_bank")
  cashBankType   String?       @map("cash_bank_type") @db.VarChar(50) // CASH, BANK
  openingBalance Decimal       @default(0.0000) @map("opening_balance") @db.Decimal(15, 4)
