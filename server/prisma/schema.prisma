model Quotation {
  id               String          @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  quotationNumber  String          @map("quotation_number") @db.VarChar(100)
  version          Int             @default(1)
  isCurrent        Boolean         @default(true) @map("is_current")
  
  customerId       String          @map("customer_id") @db.Uuid
  customer         Customer        @relation(fields: [customerId], references: [id])
  leadId           String?         @map("lead_id") @db.Uuid
  lead             Lead?           @relation(fields: [leadId], references: [id], onDelete: SetNull)
  opportunityId    String?         @map("opportunity_id") @db.Uuid
  opportunity      Opportunity?    @relation(fields: [opportunityId], references: [id], onDelete: SetNull)
  
  salespersonId    String?         @map("salesperson_id") @db.Uuid
  salesperson      User?           @relation("QuotationSalesperson", fields: [salespersonId], references: [id], onDelete: SetNull)
  
  status           String          @db.VarChar(50) // DRAFT, SUBMITTED, APPROVED, REJECTED, CONVERTED
  currency         String          @default("IQD") @db.VarChar(10)
  exchangeRate     Decimal         @default(1.0) @map("exchange_rate") @db.Decimal(15, 4)
  
  issueDate        DateTime        @map("issue_date") @db.Timestamptz
  expiryDate       DateTime        @map("expiry_date") @db.Timestamptz
  paymentTerms     String?         @map("payment_terms") @db.Text
  deliveryTerms    String?         @map("delivery_terms") @db.Text
  notes            String?         @db.Text
  internalNotes    String?         @map("internal_notes") @db.Text
  
  // Tracking Dates
  sentAt           DateTime?       @map("sent_at") @db.Timestamptz
  viewedAt         DateTime?       @map("viewed_at") @db.Timestamptz
  acceptedAt       DateTime?       @map("accepted_at") @db.Timestamptz
  rejectedAt       DateTime?       @map("rejected_at") @db.Timestamptz
  convertedAt      DateTime?       @map("converted_at") @db.Timestamptz
  
  // Approval Workflow Fields
  submittedById    String?         @map("submitted_by_id") @db.Uuid
  submittedBy      User?           @relation("QuotationSubmittedBy", fields: [submittedById], references: [id], onDelete: SetNull)
  submittedAt      DateTime?       @map("submitted_at") @db.Timestamptz
  approvedById     String?         @map("approved_by_id") @db.Uuid
  approvedBy       User?           @relation("QuotationApprovedBy", fields: [approvedById], references: [id], onDelete: SetNull)
  approvedAt       DateTime?       @map("approved_at") @db.Timestamptz
  rejectedById     String?         @map("rejected_by_id") @db.Uuid
  rejectedBy       User?           @relation("QuotationRejectedBy", fields: [rejectedById], references: [id], onDelete: SetNull)
  rejectionComment String?         @map("rejection_comment") @db.Text

  deletedAt        DateTime?       @map("deleted_at") @db.Timestamptz
  createdAt        DateTime        @default(now()) @map("created_at") @db.Timestamptz
  updatedAt        DateTime        @default(now()) @updatedAt @map("updated_at") @db.Timestamptz

  items            QuotationItem[]
  salesOrders      SalesOrder[]

  @@unique([quotationNumber, version])
  @@index([quotationNumber])
  @@index([customerId])
  @@map("crm_quotations")
}

