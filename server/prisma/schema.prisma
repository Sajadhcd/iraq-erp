  mobile               String?       @db.VarChar(50)
  email                String?       @db.VarChar(255)
  country              String?       @db.VarChar(100)
  city                 String?       @db.VarChar(100)
  address              String?       @db.Text
  industry             String?       @db.VarChar(100)
  source               String?       @db.VarChar(100)
  assignedSalespersonId String?      @map("assigned_salesperson_id") @db.Uuid
  assignedSalesperson   User?        @relation("LeadSalesperson", fields: [assignedSalespersonId], references: [id], onDelete: SetNull)
  expectedValue        Decimal?      @map("expected_value") @db.Decimal(15, 4)
  probability          Int?          @default(0)
  status               LeadStatus    @default(NEW)
  priority             LeadPriority  @default(MEDIUM)
  notes                String?       @db.Text
  deletedAt            DateTime?     @map("deleted_at") @db.Timestamptz
