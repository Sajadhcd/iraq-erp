# ============================================
# SIMS-ERP Environment Configuration Example
# ============================================
# Copy this file to .env and modify the values

# Database
DATABASE_URL="postgresql://postgres:1234@localhost:5432/sims_db?schema=public"

# JWT Authentication
JWT_SECRET="sims-development-secret-key-not-for-production"
JWT_EXPIRY="24h"

# Server
PORT=3001
NODE_ENV=development

# CORS
CORS_ORIGINS="http://localhost:3000"

# Rate Limiting
THROTTLE_TTL=60000
THROTTLE_LIMIT=60

# Security
HELMET_ENABLED=true
COMPRESSION_ENABLED=true

# Logging
LOG_LEVEL=debug

# Frontend URL
FRONTEND_URL="http://localhost:3000"
